{
  "name": "impactbridge",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI-powered volunteer coordination platform for social impact — Built with Google Gemini, Firebase & Cloud Run",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.js\"",
    "dev:client": "vite",
    "dev:server": "node server.js",
    "build": "vite build",
    "start": "node server.js",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,jsx}\" \"server/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx}\" \"server/**/*.js\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "supertest": "^7.2.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@google-cloud/logging": "^11.2.1",
    "@google/generative-ai": "^0.24.1",
    "compression": "^1.8.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.4.1",
    "firebase": "^12.12.1",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  }
}
